{
  "manifest_version": 3,
  "name": "Save Tabs",
  "version": "1.0",
  "description": "Quickly recover closed tabs and save current tab sessions securely.",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "sessions",
    "favicon"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Save Tabs",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}